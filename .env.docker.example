# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# JWT
JWT_ACCESS_SECRET=change-me-to-random-string-at-least-32-chars
JWT_ACCESS_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=604800

# HMAC for inter-service events
EVENTS_HMAC_SECRET=change-me-to-random-string-at-least-32-chars

# PSP Webhook
PAYMENTS_WEBHOOK_SECRET=change-me-to-random-string-at-least-32-chars

# Admin seed (identity-service)
SEED_ADMIN_EMAIL=admin@sapar.kg
SEED_ADMIN_PASSWORD=change-me-to-strong-admin-password

# Grafana (GF_ADMIN_PASSWORD is required — docker-compose will error if not set)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me-in-production

# SECURITY NOTE: /metrics endpoints are unauthenticated by design (Prometheus scraping).
# In production, restrict access via:
# - Kubernetes NetworkPolicy (allow only prometheus namespace)
# - Ingress rules (do not expose /metrics externally)
# - Dedicated internal-only port (split health+metrics from public API)
