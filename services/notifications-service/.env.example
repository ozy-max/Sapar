PORT=3004
DATABASE_URL=postgresql://sapar:sapar_secret@localhost:5439/sapar_notifications
NODE_ENV=development
LOG_LEVEL=info
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-characters

NOTIF_RETRY_N=5
NOTIF_BACKOFF_SEC_LIST=5,30,120,300,900
WORKER_INTERVAL_MS=1000
PROVIDER_TIMEOUT_MS=3000

# Outbox
OUTBOX_WORKER_INTERVAL_MS=1000
OUTBOX_RETRY_N=5
OUTBOX_BACKOFF_SEC_LIST=5,30,120,300,900
OUTBOX_DELIVERY_TIMEOUT_MS=3000
EVENTS_HMAC_SECRET=change-me-hmac-secret-at-least-32-chars
OUTBOX_TARGETS=
