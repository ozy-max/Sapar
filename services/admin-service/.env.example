PORT=3005
DATABASE_URL=postgresql://sapar:sapar_secret@localhost:5441/sapar_admin
NODE_ENV=development
LOG_LEVEL=info

JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-characters
SLA_RESOLVE_HOURS=12

# HMAC for internal endpoints (shared with downstream services)
EVENTS_HMAC_SECRET=change-me-hmac-secret-at-least-32-chars

# Outbox (delivers dispute.resolved → payments-service)
OUTBOX_WORKER_INTERVAL_MS=1000
OUTBOX_RETRY_N=5
OUTBOX_BACKOFF_SEC_LIST=5,30,120,300,900
OUTBOX_DELIVERY_TIMEOUT_MS=3000
OUTBOX_TARGETS=dispute.resolved>http://payments-service:3003/internal/events

# AdminCommand max retries before FAILED_FINAL
COMMAND_MAX_RETRIES=5
