PORT=3001
DATABASE_URL=postgresql://sapar:sapar_secret@localhost:5433/sapar_identity
NODE_ENV=development
LOG_LEVEL=info

# JWT / Tokens
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-characters
JWT_ACCESS_TTL_SEC=900
REFRESH_TOKEN_TTL_SEC=2592000

# Argon2 tuning (optional, defaults: memory=65536 KiB, time=3)
# PASSWORD_HASH_MEMORY_COST=65536
# PASSWORD_HASH_TIME_COST=3
