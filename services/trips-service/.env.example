PORT=3002
DATABASE_URL=postgresql://sapar:sapar_secret@localhost:5435/sapar_trips
NODE_ENV=development
LOG_LEVEL=info

# Must match identity-service JWT_ACCESS_SECRET (HS256)
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-characters

# Outbox
OUTBOX_WORKER_INTERVAL_MS=1000
OUTBOX_RETRY_N=5
OUTBOX_BACKOFF_SEC_LIST=5,30,120,300,900
OUTBOX_DELIVERY_TIMEOUT_MS=3000
EVENTS_HMAC_SECRET=change-me-hmac-secret-at-least-32-chars
OUTBOX_TARGETS=booking.created>http://payments-service:3003/internal/events,booking.confirmed>http://payments-service:3003/internal/events,booking.cancelled>http://payments-service:3003/internal/events,booking.expired>http://payments-service:3003/internal/events,trip.cancelled>http://payments-service:3003/internal/events

# Booking Saga
BOOKING_TTL_SEC=900
EXPIRATION_WORKER_INTERVAL_MS=1000

# Admin command polling
ADMIN_BASE_URL=http://admin-service:3005
COMMAND_POLL_INTERVAL_MS=5000
COMMAND_POLL_TIMEOUT_MS=3000

# Config client
CONFIG_BASE_URL=http://admin-service:3005
CONFIG_CACHE_TTL_MS=30000
CONFIG_FETCH_TIMEOUT_MS=3000
