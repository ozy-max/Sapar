generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripStatus {
  DRAFT
  ACTIVE
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  EXPIRED
}

model City {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  countryCode String   @map("country_code")
  lat         Float
  lon         Float
  createdAt   DateTime @default(now()) @map("created_at")

  tripsFrom Trip[] @relation("TripFromCity")
  tripsTo   Trip[] @relation("TripToCity")

  @@unique([countryCode, name])
  @@index([name])
  @@map("cities")
}

model Trip {
  id             String     @id @default(uuid()) @db.Uuid
  driverId       String     @map("driver_id") @db.Uuid
  fromCity       String     @map("from_city")
  toCity         String     @map("to_city")
  fromCityId     String?    @map("from_city_id") @db.Uuid
  toCityId       String?    @map("to_city_id") @db.Uuid
  fromLat        Float?     @map("from_lat")
  fromLon        Float?     @map("from_lon")
  toLat          Float?     @map("to_lat")
  toLon          Float?     @map("to_lon")
  departAt       DateTime   @map("depart_at")
  seatsTotal     Int        @map("seats_total")
  seatsAvailable Int        @map("seats_available")
  priceKgs       Int        @map("price_kgs")
  status         TripStatus @default(ACTIVE)
  completedAt    DateTime?  @map("completed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  bookings   Booking[]
  fromCityRel City? @relation("TripFromCity", fields: [fromCityId], references: [id], onDelete: SetNull)
  toCityRel   City? @relation("TripToCity", fields: [toCityId], references: [id], onDelete: SetNull)

  @@index([fromCity, toCity, departAt])
  @@index([driverId, departAt])
  @@index([fromCityId, toCityId, departAt])
  @@map("trips")
}

model Booking {
  id          String        @id @default(uuid()) @db.Uuid
  tripId      String        @map("trip_id") @db.Uuid
  passengerId String        @map("passenger_id") @db.Uuid
  seats       Int           @default(1)
  status      BookingStatus @default(PENDING_PAYMENT)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([passengerId])
  @@map("bookings")
}

model ConsumedEvent {
  eventId    String   @id @map("event_id") @db.Uuid
  eventType  String   @map("event_type")
  consumedAt DateTime @default(now()) @map("consumed_at")
  producer   String
  traceId    String   @map("trace_id")

  @@map("consumed_events")
}

model IdempotencyRecord {
  id        String   @id @default(uuid()) @db.Uuid
  key       String
  userId    String   @map("user_id") @db.Uuid
  response  Json
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([key, userId])
  @@map("idempotency_records")
}

enum OutboxEventStatus {
  PENDING
  SENT
  FAILED_RETRY
  FAILED_FINAL
}

model OutboxEvent {
  id          String            @id @db.Uuid
  eventType   String            @map("event_type")
  payloadJson Json              @map("payload_json")
  occurredAt  DateTime          @map("occurred_at")
  traceId     String            @map("trace_id")
  status      OutboxEventStatus @default(PENDING)
  tryCount    Int               @default(0) @map("try_count")
  nextRetryAt DateTime          @default(now()) @map("next_retry_at")
  lastError   String?           @map("last_error")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@index([status, nextRetryAt])
  @@index([eventType])
  @@map("outbox_events")
}
