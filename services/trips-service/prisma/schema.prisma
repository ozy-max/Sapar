generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripStatus {
  DRAFT
  ACTIVE
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  ACTIVE
  CANCELLED
}

model Trip {
  id             String     @id @default(uuid()) @db.Uuid
  driverId       String     @map("driver_id") @db.Uuid
  fromCity       String     @map("from_city")
  toCity         String     @map("to_city")
  departAt       DateTime   @map("depart_at")
  seatsTotal     Int        @map("seats_total")
  seatsAvailable Int        @map("seats_available")
  priceKgs       Int        @map("price_kgs")
  status         TripStatus @default(ACTIVE)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  bookings Booking[]

  @@index([fromCity, toCity, departAt])
  @@index([driverId, departAt])
  @@map("trips")
}

model Booking {
  id          String        @id @default(uuid()) @db.Uuid
  tripId      String        @map("trip_id") @db.Uuid
  passengerId String        @map("passenger_id") @db.Uuid
  seats       Int           @default(1)
  status      BookingStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, passengerId])
  @@map("bookings")
}

model IdempotencyRecord {
  id        String   @id @default(uuid()) @db.Uuid
  key       String
  userId    String   @map("user_id") @db.Uuid
  response  Json
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([key, userId])
  @@map("idempotency_records")
}
