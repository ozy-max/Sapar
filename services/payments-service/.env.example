PORT=3003
DATABASE_URL=postgresql://sapar:sapar_secret@localhost:5437/sapar_payments
NODE_ENV=development
LOG_LEVEL=info

JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-characters

PSP_TIMEOUT_MS=5000
PAYMENTS_WEBHOOK_SECRET=change-me-webhook-secret-at-least-32-chars

RECEIPT_RETRY_N=3
RECEIPT_BACKOFF_SEC_LIST=5,30,300
RECEIPT_POLL_INTERVAL_MS=5000

# Outbox
OUTBOX_WORKER_INTERVAL_MS=1000
OUTBOX_RETRY_N=5
OUTBOX_BACKOFF_SEC_LIST=5,30,120,300,900
OUTBOX_DELIVERY_TIMEOUT_MS=3000
EVENTS_HMAC_SECRET=change-me-hmac-secret-at-least-32-chars
OUTBOX_TARGETS=payment.intent.hold_placed>http://trips-service:3002/internal/events,payment.intent.failed>http://trips-service:3002/internal/events,payment.captured>http://notifications-service:3004/internal/events,payment.cancelled>http://notifications-service:3004/internal/events,payment.refunded>http://notifications-service:3004/internal/events

# Config client
CONFIG_BASE_URL=http://admin-service:3005
CONFIG_CACHE_TTL_MS=30000
CONFIG_FETCH_TIMEOUT_MS=3000
