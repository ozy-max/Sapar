generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentIntentStatus {
  CREATED
  HOLD_PLACED
  CAPTURED
  CANCELLED
  REFUNDED
  FAILED
}

enum PaymentEventType {
  INTENT_CREATED
  HOLD_PLACED
  CAPTURE_REQUESTED
  CAPTURED
  CANCEL_REQUESTED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
  FAILED
  WEBHOOK_RECEIVED
}

enum ReceiptStatus {
  PENDING
  ISSUED
  FAILED_FINAL
}

model PaymentIntent {
  id             String              @id @default(uuid()) @db.Uuid
  bookingId      String              @unique @map("booking_id") @db.Uuid
  payerId        String              @map("payer_id") @db.Uuid
  amountKgs      Int                 @map("amount_kgs")
  currency       String              @default("KGS")
  status         PaymentIntentStatus @default(CREATED)
  pspProvider    String              @default("fake") @map("psp_provider")
  pspIntentId    String?             @map("psp_intent_id")
  idempotencyKey String?             @map("idempotency_key")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  events   PaymentEvent[]
  receipts Receipt[]

  @@unique([idempotencyKey, payerId])
  @@index([status])
  @@map("payment_intents")
}

model PaymentEvent {
  id              String           @id @default(uuid()) @db.Uuid
  paymentIntentId String           @map("payment_intent_id") @db.Uuid
  type            PaymentEventType
  externalEventId String?          @unique @map("external_event_id")
  payloadJson     Json             @default("{}") @map("payload_json")
  createdAt       DateTime         @default(now()) @map("created_at")

  paymentIntent PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)

  @@index([paymentIntentId])
  @@map("payment_events")
}

model Receipt {
  id              String        @id @default(uuid()) @db.Uuid
  paymentIntentId String        @map("payment_intent_id") @db.Uuid
  status          ReceiptStatus @default(PENDING)
  tryCount        Int           @default(0) @map("try_count")
  nextRetryAt     DateTime      @default(now()) @map("next_retry_at")
  lastError       String?       @map("last_error")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  paymentIntent PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@map("receipts")
}
