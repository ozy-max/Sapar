PORT=3000
DATABASE_URL=postgresql://sapar:sapar_secret@localhost:5432/sapar_gateway
NODE_ENV=development
LOG_LEVEL=info

# Downstream service URLs
IDENTITY_BASE_URL=http://localhost:3001
TRIPS_BASE_URL=http://localhost:3002
PAYMENTS_BASE_URL=http://localhost:3003

# High-load proxy settings
HTTP_TIMEOUT_MS=3000
MAX_BODY_BYTES=1048576

# BFF aggregation timeout (should be < HTTP_TIMEOUT_MS to leave room for BFF logic)
BFF_TIMEOUT_MS=2500

# Redis (centralized rate limiter store)
REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT_MS=500

# Trust proxy — set to true behind a trusted reverse proxy (nginx, ALB)
# When true, X-Forwarded-For leftmost IP is used as client key
TRUST_PROXY=false

# Rate limiting (requests per minute per key, per upstream prefix)
RATE_IDENTITY_RPM=60
RATE_TRIPS_RPM=120
RATE_PAYMENTS_RPM=30
RATE_LIMIT_WINDOW_SEC=60
