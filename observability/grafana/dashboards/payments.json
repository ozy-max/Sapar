{
  "uid": "sapar-payments",
  "title": "Sapar Payments",
  "tags": ["sapar", "payments"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "PSP Call Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (operation, le) (rate(external_call_duration_ms_bucket{service=\"payments-service\", provider=\"psp\"}[5m])))",
          "legendFormat": "p50 {{operation}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(external_call_duration_ms_bucket{service=\"payments-service\", provider=\"psp\"}[5m])))",
          "legendFormat": "p95 {{operation}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "PSP Call Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 30, "lineWidth": 1 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (operation) (rate(external_call_errors_total{service=\"payments-service\", provider=\"psp\"}[5m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Receipt Issuer Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(external_call_duration_ms_bucket{service=\"payments-service\", provider=\"receipt_issuer\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(external_call_duration_ms_bucket{service=\"payments-service\", provider=\"receipt_issuer\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Receipt Issuer Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 30, "lineWidth": 1 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(external_call_errors_total{service=\"payments-service\", provider=\"receipt_issuer\"}[5m]))",
          "legendFormat": "receipt errors/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Receipt Statuses (issued / pending / failed_final)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 1, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "issued" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "pending" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "failed_final" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(receipt_status_total{service=\"payments-service\"}[5m])) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "DB Query Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (operation, le) (rate(db_query_duration_ms_bucket{service=\"payments-service\"}[5m])))",
          "legendFormat": "p95 {{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "App Error Codes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 30, "lineWidth": 1 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (code) (rate(app_errors_total{service=\"payments-service\"}[5m]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ]
    }
  ]
}
