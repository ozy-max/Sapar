{
  "uid": "sapar-overview",
  "title": "Sapar Overview",
  "tags": ["sapar"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "RPS per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total[5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "p50 Latency per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (service, le) (rate(http_request_duration_ms_bucket[5m])))",
          "legendFormat": "p50 {{service}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_ms_bucket[5m])))",
          "legendFormat": "p95 {{service}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "4xx Rate per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 30, "lineWidth": 1 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total{status=~\"4..\"}[5m]))",
          "legendFormat": "4xx {{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "5xx Rate per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 30, "lineWidth": 1 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_server_errors_total[5m]))",
          "legendFormat": "5xx {{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top Error Codes (last 5m)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "transformations": [
        { "id": "sortBy", "options": { "sort": [{ "field": "Value", "desc": true }] } }
      ],
      "targets": [
        {
          "expr": "topk(10, sum by (service, code) (increase(app_errors_total[5m])))",
          "legendFormat": "{{service}} — {{code}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "In-Flight Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "http_in_flight_requests",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    }
  ]
}
