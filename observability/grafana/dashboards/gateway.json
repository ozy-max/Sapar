{
  "uid": "sapar-gateway",
  "title": "Sapar Gateway",
  "tags": ["sapar", "gateway"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Rate Limited Requests (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 40, "lineWidth": 1 },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(app_errors_total{service=\"api-gateway\", code=\"RATE_LIMITED\"}[5m])) * 60",
          "legendFormat": "Rate limited / min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Upstream Errors (Proxy)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (code) (rate(app_errors_total{service=\"api-gateway\", code=~\"DOWNSTREAM_.*|BAD_GATEWAY|PAYLOAD_TOO_LARGE\"}[5m]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Redis Latency (rate-limiter)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(redis_request_duration_ms_bucket{service=\"api-gateway\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(redis_request_duration_ms_bucket{service=\"api-gateway\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(redis_request_duration_ms_bucket{service=\"api-gateway\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Redis Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "bars", "fillOpacity": 30, "lineWidth": 1 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (operation) (rate(redis_errors_total{service=\"api-gateway\"}[5m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Gateway RPS by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{service=\"api-gateway\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    }
  ]
}
